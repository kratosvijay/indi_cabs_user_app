# Uncomment this line to define a global platform for your project
platform :ios, '16.0'

# CocoaPods analytics sends network stats synchronously affecting flutter build latency.
ENV['COCOAPODS_DISABLE_STATS'] = 'true'

project 'Runner', {
  'Debug' => :debug,
  'Profile' => :release,
  'Release' => :release,
}

def flutter_root
  generated_xcode_build_settings_path = File.expand_path(File.join('..', 'Flutter', 'Generated.xcconfig'), __FILE__)
  unless File.exist?(generated_xcode_build_settings_path)
    raise "#{generated_xcode_build_settings_path} must exist. If you're running pod install manually, make sure flutter pub get is executed first"
  end

  File.foreach(generated_xcode_build_settings_path) do |line|
    matches = line.match(/FLUTTER_ROOT\=(.*)/)
    return matches[1].strip if matches
  end
  raise "FLUTTER_ROOT not found in #{generated_xcode_build_settings_path}. Try deleting Generated.xcconfig, then run flutter pub get"
end

require File.expand_path(File.join('packages', 'flutter_tools', 'bin', 'podhelper'), flutter_root)

flutter_ios_podfile_setup

inhibit_all_warnings!

target 'Runner' do
  use_frameworks!

  flutter_install_all_ios_pods File.dirname(File.realpath(__FILE__))
  target 'RunnerTests' do
    inherit! :search_paths
  end
end

post_install do |installer|
  installer.pods_project.targets.each do |target|
    flutter_additional_ios_build_settings(target)

    # Global fix for strict header inclusion (affects leveldb, AppAuth, etc.)
    # and code signing for simulator.
    target.build_configurations.each do |config|
      # Enable permission_handler permissions
      config.build_settings['GCC_PREPROCESSOR_DEFINITIONS'] ||= [
        '$(inherited)',
        'PERMISSION_LOCATION=1',
        'PERMISSION_CONTACTS=1',
        'PERMISSION_NOTIFICATIONS=1',
      ]

      config.build_settings['CLANG_WARN_QUOTED_INCLUDE_IN_FRAMEWORK_HEADER'] = 'NO'
      config.build_settings['GCC_WARN_ABOUT_DEPRECATED_FUNCTIONS'] = 'NO'
      config.build_settings['CODE_SIGNING_REQUIRED'] = "NO"
      config.build_settings['CODE_SIGN_IDENTITY[sdk=iphonesimulator*]'] = "-"
      config.build_settings['IPHONEOS_DEPLOYMENT_TARGET'] = '16.0'
      # Suppress duplicate -lc++ linker warnings (harmless, multiple pods depend on libc++)
      ldflags = config.build_settings['OTHER_LDFLAGS']
      flag = '-Wl,-no_warn_duplicate_libraries'
      if ldflags.is_a?(Array)
        ldflags << flag unless ldflags.include?(flag)
      elsif ldflags.is_a?(String)
        config.build_settings['OTHER_LDFLAGS'] = "#{ldflags} #{flag}" unless ldflags.include?(flag)
      else
        config.build_settings['OTHER_LDFLAGS'] = ['$(inherited)', flag]
      end

      # Force Flutter engine search paths
      f_root = flutter_root
      # Point to the ios-arm64 slice of the xcframework
      engine_dir = File.join(f_root, 'bin', 'cache', 'artifacts', 'engine', 'ios', 'Flutter.xcframework', 'ios-arm64')
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] ||= ['$(inherited)']
      config.build_settings['FRAMEWORK_SEARCH_PATHS'] << "\"#{engine_dir}\""
      config.build_settings['HEADER_SEARCH_PATHS'] ||= ['$(inherited)']
      config.build_settings['HEADER_SEARCH_PATHS'] << "\"#{engine_dir}\""
    end

    # Suppress "Create Symlinks to Header Folders will run every build" warnings
    target.build_phases.each do |phase|
      next unless phase.respond_to?(:name) && phase.name&.include?('Create Symlinks')
      phase.always_out_of_date = '1'
    end
  end
end
