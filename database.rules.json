{
  "rules": {
    "drivers": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid",
        "location": {
          ".read": "auth != null",
          ".write": "$uid === auth.uid"
        }
      }
    },
    "presence": {
      "$uid": {
        ".read": "auth != null",
        ".write": "$uid === auth.uid"
      }
    },
    "driver_locations": {
      ".read": "auth != null",
      "$driverId": {
        ".write": "auth != null"
      }
    },
    "ride_requests": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "rental_requests": {
      ".read": "auth != null",
      ".write": "auth != null"
    },
    "$other": {
      ".read": "auth != null",
      ".write": "auth != null"
    }
  }
}
