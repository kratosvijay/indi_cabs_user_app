rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    
    // --- Driver Profile Pictures ---
    match /driver_profile_pictures/{fileName} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // --- Driver Verification Documents ---
    match /driver_documents/{driverId}/{document=**} {
      allow read, write: if request.auth != null;
    }
    match /drivers/{driverId}/{allPaths=**} {
      allow read, write: if request.auth != null;
    }

    // --- Fleet Verification Documents ---
    match /fleet_documents/{document=**} {
      allow read, write: if request.auth != null;
    }

    // --- General User Profiles ---
    match /user_profiles/{userId}/{document=**} {
       allow read: if request.auth != null;
       allow write: if request.auth != null && request.auth.uid == userId;
    }
    match /users/{userId}/{allPaths=**} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    // --- Public ---
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Default catch-all
    match /{allPaths=**} {
      allow read, write: if request.auth != null;
    }
  }
}
