rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- HELPER FUNCTIONS ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isDriverOwner(driverId) {
      return isSignedIn() && (
        request.auth.uid == driverId ||
        resource.data.get('uid', '') == request.auth.uid
      );
    }

    function isDriverOwnerByGet(driverId) {
      return isSignedIn() && (
        request.auth.uid == driverId ||
        get(/databases/$(database)/documents/drivers/$(driverId)).data.get('uid', '') == request.auth.uid
      );
    }

    function isUser() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function isPhoneOwner() {
      return isSignedIn() && (
        resource.data.get('phoneNumber', '') == request.auth.token.get('phone_number', '') ||
        resource.data.get('phone', '') == request.auth.token.get('phone_number', '')
      );
    }

    // --- DEFAULT DENY ---
    match /{document=**} {
      allow read, write: if false;
    }

    // --- USERS COLLECTION ---
    match /users/{userId} {
      allow read: if isOwner(userId) || isSignedIn(); // Drivers need to read user details for active rides. allow get/list might be better, but we let signed-in users read.
      allow create: if isOwner(userId);
      allow update: if isOwner(userId);
      allow delete: if false;

      match /{subcollection=**} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- DRIVERS COLLECTION ---
    match /drivers/{driverId} {
      allow get: if isSignedIn();
      allow list: if true; // Allows unauthenticated list for phone-number duplicate check during signup.

      allow create: if isSignedIn() && (
        request.auth.uid == driverId ||
        request.resource.data.get('uid', '') == request.auth.uid
      );

      allow update: if isDriverOwner(driverId) || isUser() || isPhoneOwner(); // Users rate drivers / update status
      allow delete: if false;

      match /{subcollection=**} {
        allow read, write: if isDriverOwnerByGet(driverId);
      }
    }

    // --- DRIVER RIDE QUEUE ---
    match /driver_ride_queue/{driverId} {
      allow read, write: if isSignedIn() && request.auth.uid == driverId;
    }

    // --- RIDE REQUESTS ---
    match /ride_requests/{rideId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- RENTAL REQUESTS ---
    match /rental_requests/{rideId} {
      allow read, write: if isSignedIn();

      match /messages/{messageId} {
        allow read, write: if isSignedIn();
      }
    }

    // --- OTP VERIFICATIONS ---
    match /otp_verifications/{phoneNumber} {
      // Allow users to initiate their own OTP verified by their phone number in Auth token
      allow read, write: if isSignedIn() && (
        phoneNumber == request.auth.token.phone_number || 
        phoneNumber == request.auth.token.get('phone_number', '')
      );
    }

    // --- FLEET OPERATORS ---
    match /fleet_operators/{operatorId} {
      allow get: if isOwner(operatorId);
      allow list: if true;
      allow create: if isOwner(operatorId);
      allow update: if isOwner(operatorId) || isPhoneOwner();
      allow delete: if isOwner(operatorId) || isPhoneOwner();
    }

    // --- EARNINGS ---
    match /earnings/{earningId} {
      allow read: if isSignedIn() && (
        resource.data.driverUid == request.auth.uid ||
        resource.data.driverId == request.auth.uid
      );
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // --- WALLET TRANSACTIONS & INVOICES ---
    match /wallet_transactions/{txId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions
    }
    match /invoices/{invoiceId} {
      allow read: if isSignedIn() && (
        resource.data.userId == request.auth.uid ||
        resource.data.driverUid == request.auth.uid ||
        resource.data.driverId == request.auth.uid
      );
      allow write: if false; 
    }

    // --- PRICING / GEOS / PACKAGES ---
    match /pricing_rules/{ruleId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /geofenced_zones/{zoneId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /rental_packages/{packageId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
    match /demand_zones/{zoneId} {
      allow read: if isSignedIn();
      allow write: if false;
    }

    // --- AIRPORT QUEUES ---
    match /airport_queues/{queueId} {
      allow read: if isSignedIn();
      allow write: if false; // Cloud Functions only

      match /drivers/{driverId} {
        allow read: if isSignedIn();
        allow create, update, delete: if isDriverOwnerByGet(driverId);
      }
    }

    // --- REVIEWS ---
    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isSignedIn();
      allow update, delete: if false;
    }

    // --- VEHICLES ---
    match /vehicles/{vehicleId} {
      allow read: if isSignedIn();
      allow update: if isSignedIn() &&
        (request.resource.data.assignedDriverId == request.auth.uid ||
         (resource.data.assignedDriverId == request.auth.uid &&
          request.resource.data.assignedDriverId == null));
      allow create, delete: if false;
    }

    // --- COUNTERS ---
    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if isSignedIn();
    }

    // --- RIDE REWARDS ---
    // Document ID == user UID. Users can read their own reward status.
    // Writes are performed exclusively by Cloud Functions (processRideRewards).
    match /user_rewards/{userId} {
      allow read: if isOwner(userId);
      allow write: if false; // Cloud Functions only
    }

    // --- ADMINS ---
    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if false;
    }


    // --- METRO BOOKINGS ---
    match /metro_bookings/{bookingId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false;
    }

    // --- SUPPORT TICKETS ---
    match /support_tickets/{ticketId} {
      allow create: if isSignedIn();
      
      allow read, update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        resource.data.driverId == request.auth.uid ||
        resource.data.driverUid == request.auth.uid ||
        (request.auth.uid in resource.data.get('admins', [])) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
      
      allow list: if isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      
      allow update: if isSignedIn() && (
        (request.auth.uid in resource.data.get('admins', [])) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ) && request.resource.data.status == 'closed';

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid ||
          get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.driverId == request.auth.uid ||
          get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.driverUid == request.auth.uid ||
          (request.auth.uid in get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.get('admins', [])) ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
      }
    }
  }
}
