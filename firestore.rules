rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    function isDriver() {
      return isSignedIn() && exists(/databases/$(database)/documents/drivers/$(request.auth.uid));
    }
    function isUser() {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    // --- Users Collection ---
    match /users/{userId} {
      allow read, write: if isOwner(userId);
      allow read, update: if isDriver(); // Drivers can see and update user details for active rides
      
      match /favorites/{favoriteId} {
        allow read, write: if isOwner(userId);
      }
      match /payment_history/{paymentId} {
        allow read: if isOwner(userId);
        allow write: if false; // Only Cloud Functions should update this
      }
      match /notifications/{notifId} {
        allow read, write: if isOwner(userId);
      }
    }

    // --- Drivers Collection ---
    match /drivers/{driverId} {
      allow read, write: if isOwner(driverId);
      allow read, update: if isUser(); // Passengers can see and update driver ratings
      allow read: if true; // Allow public tracking
    }

    // --- Ride Requests ---
    match /ride_requests/{rideId} {
      allow create: if isUser();
      allow read: if true; // Allow public tracking
      allow update: if isOwner(resource.data.userId) || isOwner(resource.data.driverId) || (isDriver() && resource.data.driverId == request.auth.uid) || (isDriver() && resource.data.status == 'searching');
      
      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/ride_requests/$(rideId)).data.userId) || isOwner(get(/databases/$(database)/documents/ride_requests/$(rideId)).data.driverId));
      }
    }

    // --- Rental Requests ---
    match /rental_requests/{rideId} {
      allow create: if isUser();
      allow read: if true; // Allow public tracking
      allow update: if isOwner(resource.data.userId) || isOwner(resource.data.driverId) || (isDriver() && resource.data.driverId == request.auth.uid) || (isDriver() && resource.data.status == 'searching');

      match /messages/{messageId} {
        allow read, write: if isSignedIn() && (isOwner(get(/databases/$(database)/documents/rental_requests/$(rideId)).data.userId) || isOwner(get(/databases/$(database)/documents/rental_requests/$(rideId)).data.driverId));
      }
    }

    // --- Pricing Rules & Geofences ---
    match /pricing_rules/{city} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only (manual/CLI)
    }
    match /geofenced_zones/{zoneId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only
    }

    match /rental_packages/{packageId} {
      allow read: if isSignedIn();
      allow write: if false; // Admin only
    }

    match /reviews/{reviewId} {
      allow read: if isSignedIn();
      allow create: if isUser() || isDriver();
      allow update, delete: if false;
    }

    // --- Fleet Operators ---
    match /fleet_operators/{operatorId} {
      allow read, write: if isOwner(operatorId);
    }

    // --- Earnings ---
    match /earnings/{earningId} {
      allow read: if isSignedIn() && resource.data.driverId == request.auth.uid;
      allow create: if isDriver(); // Allow driver to post earnings
      allow update, delete: if false;
    }

    // --- Counters ---
    match /counters/{counterId} {
      allow read: if isSignedIn();
      allow write: if false; // Only Cloud Functions
    }

    // --- Metro Bookings ---
    match /metro_bookings/{bookingId} {
      allow create: if isSignedIn() && request.resource.data.userId == request.auth.uid;
      allow read: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow update, delete: if false; // For now, only creation and reading by owner
    }

    // --- Support Ticketing ---
    match /support_tickets/{ticketId} {
      allow create: if isSignedIn();
      
      // Allow read/update if the user is the owner OR if their UID IS in the authorized admins list
      allow read, update: if isSignedIn() && (
        resource.data.userId == request.auth.uid || 
        (request.auth.uid in resource.data.get('admins', [])) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      );
      
      // ADMIN LISTING: Allow listing all tickets if the user is in the global admins collection
      allow list: if isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
      
      // RESTRICTION: Only admins can close a ticket
      allow update: if isSignedIn() && (
        (request.auth.uid in resource.data.get('admins', [])) ||
        exists(/databases/$(database)/documents/admins/$(request.auth.uid))
      ) && request.resource.data.status == 'closed';

      match /messages/{messageId} {
        // Optimization: Use a helper to check parent ticket authorization
        allow read, write: if isSignedIn() && (
          get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.userId == request.auth.uid ||
          (request.auth.uid in get(/databases/$(database)/documents/support_tickets/$(ticketId)).data.get('admins', [])) ||
          exists(/databases/$(database)/documents/admins/$(request.auth.uid))
        );
      }
    }
  }
}
